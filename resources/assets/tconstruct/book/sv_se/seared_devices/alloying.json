    {
      "text": "\n"
    },
    {
      "text": "§lAlumite"
    },
    {
      "text": "\n"
    },
    {
      "text": "Aluminum(1), Iron(1), and Obsidian(1)"
    },
    {
      "text": "\n"
    },
    {
