    {
      "text": "\n"
    },
    {
      "text": "§lBronze"
    },
    {
      "text": "\n"
    },
    {
      "text": "Copper(3) and Tin(1)"
    },
    {
      "text": "\n"
    },
    {
      "text": "§lAluminum Brass"
    },
    {
      "text": "\n"
    },
    {
      "text": "Aluminum(3) and Copper(1)"
    },
    {
      "text": "\n"
    },
    {
      "text": "§lManyullyn"
    },
    {
      "text": "\n"
    },
    {
      "text": "Cobalt(2) and Ardite(2)"
